{
  "name": "@bernankez/ai",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@bernankez/eslint-config": "^5.0.1",
    "@inquirer/prompts": "^8.3.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "lint-staged": "^16.1.0",
    "picocolors": "^1.1.1",
    "simple-git-hooks": "^2.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
